{
  "name": "@hermanos-ti/internal_lib",
  "private": false,
  "version": "0.2.1",
  "type": "module",
  "main": "./dist/internal_lib.umd.js",
  "module": "./dist/internal_lib.es.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hermanos-ti/internal_lib.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "exports": {
    ".": {
      "import": "./dist/internal_lib.es.js",
      "require": "./dist/internal_lib.umd.js"
    },
    "./dist/style.css": "./dist/internal_lib.css"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite --host",
    "build": "vite build && node -e \"require('fs').copyFileSync('src/index.d.ts','dist/index.d.ts')\"",
    "analyze": "npm run build && open stats.html",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@storybook/addon-docs": "^10.4.5",
    "@storybook/addon-onboarding": "^10.4.5",
    "@storybook/react-vite": "^10.4.5",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react-swc": "^4.1.0",
    "baseline-browser-mapping": "^2.9.18",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "eslint-plugin-storybook": "^10.4.5",
    "globals": "^16.4.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "storybook": "^10.4.5",
    "vite": "npm:rolldown-vite@7.1.12",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@7.1.12"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  }
}
